      "suggestion": "Frantzve"
    },
    {
      "id": "erica_not_erika",
      "regex": "\\bErica\\b",
      "flags": [],
      "hint": "House style is Erika",
      "suggestion": "Erika"
    },
    {
      "id": "candice",
      "regex": "\\bCandice\\b",
      "flags": [],
      "hint": "Host spelling is Candace",
      "suggestion": "Candace"
    },
    {
      "id": "cocopah_stt",
      "regex": "Thanks alumni Erika France for|Thanks alumni Erica France for|AOPA pride",
      "flags": ["IGNORECASE"],
      "hint": "Tweet uses @ErikaFrantzve and #CocopahPRIDE",
