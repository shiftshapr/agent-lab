{
  "version": 1,
  "description": "Heuristics for Draft Editor transcript review (not CI). Expand as needed.",
  "patterns": [
    {
      "id": "lorie_france",
      "regex": "\\bLorie France\\b",
      "flags": ["IGNORECASE"],
      "hint": "STT often means Lori Frantzve",
      "suggestion": "Lori Frantzve"
    },
    {
      "id": "kenton_lorie",
      "regex": "Kenton Lorie",
      "flags": ["IGNORECASE"],
      "hint": "STT for Kent and Lori Frantzve",
      "suggestion": "Kent and Lori Frantzve"
    },
    {
      "id": "kent_wasnt",
      "regex": "\\bKent wasn\\b",
      "flags": ["IGNORECASE"],
      "hint": "STT mangled Frantzve",
      "suggestion": "Kent Frantzve"
    },
    {
      "id": "france_gwinta",
      "regex": "France,\\s*Gwinta",
      "flags": ["IGNORECASE"],
      "hint": "Name chain: Frantzve + Guinta",
      "suggestion": "Frantzve, Guinta"
    },
    {
      "id": "gwinta",
      "regex": "\\bGwinta\\b",
      "flags": ["IGNORECASE"],
