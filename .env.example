# Agent Lab — copy to .env and fill in

# Outbound Telegram/Slack/DeerFlow channels: convert markdown tables etc. to plain text (default).
# Set to 1 to send raw agent markdown (debug only).
# CHANNEL_MESSAGE_RAW=0

OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=fake
MODEL_NAME=qwen2.5:7b

# GitHub PAT for scripts/pacha-slate-github-bootstrap/setup_github_api.py (optional).
# agent-lab/.env is gitignored — never commit real tokens.
# GITHUB_TOKEN=

# MiniMax (optional, faster)
# MINIMAX_API_KEY=
# MINIMAX_MODEL=MiniMax-M2.5

# Transcript API (optional; youtube-transcript-api works without for public captions)
# TRANSCRIPT_API_KEY=

# Neo4j (optional, for graph-based ledger and validation)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=openclaw
# NEO4J_AUTO_INGEST=true

# MCP servers (for PAI agents via DeerFlow extensions_config.json)
# Slack — one set per workspace. Install same app in each workspace, get token per workspace.
# Workspace 1: SLACK_BOT_TOKEN_1, SLACK_TEAM_ID_1, SLACK_CHANNEL_IDS_1 (optional)
# SLACK_BOT_TOKEN_1=
# SLACK_TEAM_ID_1=
# SLACK_CHANNEL_IDS_1=

# Workspace 2
# SLACK_BOT_TOKEN_2=
# SLACK_TEAM_ID_2=
# SLACK_CHANNEL_IDS_2=

# Workspace 3 (add more: _4, _5, ... and enable in extensions_config.json)
# SLACK_BOT_TOKEN_3=
# SLACK_TEAM_ID_3=
# SLACK_CHANNEL_IDS_3=

# Stripe — from dashboard.stripe.com/apikeys (use Restricted API Key for agents)
# STRIPE_SECRET_KEY=

# Phantom — App ID from phantom.com/portal
# PHANTOM_APP_ID=

# Brief delivery (for cron-daily-prep when SEND_BRIEF=1)
# Telegram: from @BotFather + @userinfobot for chat ID
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Long free-form / DP jobs via Shiftshapr + DeerFlow (optional)
# SHIFTSHAPR_DEERFLOW_TIMEOUT=1200
# DEERFLOW_TASK_RECURSION_LIMIT=200
# SHIFTSHAPR_DEERFLOW_ACK=1
# Bride of Charlie via Shiftshapr /bride: append link only (no run_full_workflow on the server)
# BRIDE_TG_RUN_WORKFLOW=0
# Slack: channel ID (right-click channel → View details)
# SLACK_DELIVERY_CHANNEL_ID=
# SLACK_DELIVERY_TOKEN=   # or use SLACK_BOT_TOKEN_1
# SEND_BRIEF=1            # enable delivery after daily-prep

# Discord (optional; enable in extensions_config.json)
# DISCORD_BOT_TOKEN=

# LinkedIn + X — session for Playwright MCP (run ./scripts/ensure-playwright-mcp-browsers.sh, then scripts/linkedin-login-setup.py)
# PLAYWRIGHT_MCP_WRAPPER=/path/to/agent-lab/scripts/playwright-mcp-with-linkedin.sh
# LINKEDIN_STORAGE_STATE=/path/to/agent-lab/data/linkedin_state.json

# OpenAI DALL-E — for image generation (scripts/generate-image-dalle.py)
# OPENAI_IMAGE_API_KEY=sk-...   # Your OpenAI API key (platform.openai.com)

# Draft Editor (apps/draft_editor) — http://localhost:8081
# DRAFT_EDITOR_USER=draft
# DRAFT_EDITOR_PASSWORD=your-secret
# DRAFT_EDITOR_PORT=8081
# DRAFT_EDITOR_LOCAL_URL=http://127.0.0.1:8081  # optional; “open locally” link in trycloudflare banner (default uses PORT or 8081)
# DRAFT_EDITOR_SHOW_LOCAL_FALLBACK_BANNER=1     # optional; show yellow localhost tip on any non-local host (default: only *.trycloudflare.com)
# DRAFT_EDITOR_HIDE_LOCAL_FALLBACK_BANNER=1    # optional; never show that tip
# DRAFT_EDITOR_LOCAL_FALLBACK_BANNER_HOST_SUFFIXES=example.dev  # optional; comma suffixes to show tip (e.g. another quick-tunnel pattern)

# Master calendar — public read + .ics for phone/watch (optional)
# CALENDAR_EMBED_TOKEN=long-random-string   # required for /api/calendar/public and /api/calendar/feed.ics
# CALENDAR_PUBLIC_BASE_URL=https://your-public-host  # optional; links draft URLs in .ics (not localhost on mobile)
# Free quick tunnel: run ./scripts/cloudflared-draft-editor.sh and paste the trycloudflare.com URL here (see docs/CLOUDFLARED_DRAFT_EDITOR.md)
