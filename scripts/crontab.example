# Agent Lab — cron entries
# Add these with: crontab -e
# Or: (crontab -l 2>/dev/null; cat scripts/crontab.example) | crontab -

# Daily prep at 6am (calendar + email brief)
0 6 * * * cd /Users/shiftshapr/workspace/agent-lab && ./scripts/cron-daily-prep.sh

# Email opportunity search at 7am
0 7 * * * cd /Users/shiftshapr/workspace/agent-lab && ./scripts/cron-email-opportunity.sh

# Weekly preview Sunday 6pm (SEND_BRIEF=1 for delivery)
0 18 * * 0 cd /Users/shiftshapr/workspace/agent-lab && ./scripts/cron-weekly-preview.sh

# Meeting reminders every 5 min, 6am–10pm (15 min → 5 min if no ack)
*/5 6-22 * * * cd /Users/shiftshapr/workspace/agent-lab && ./scripts/cron-meeting-reminder.sh

# LinkedIn replies digest at 9am, 2pm, 6pm (requires LINKEDIN_STORAGE_STATE)
0 9,14,18 * * * cd /Users/shiftshapr/workspace/agent-lab && ./scripts/cron-linkedin-replies.sh
